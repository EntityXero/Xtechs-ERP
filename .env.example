# ──────────────────────────────────────────────
# Xtechs ERP — Environment Variables
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────────

# ─── Database ─────────────────────────────────
DATABASE_URL=postgresql://erp_dev:erp_dev_pass@localhost:5432/xtechs_erp

# ─── Redis (optional early stage) ─────────────
# REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ─── Auth ─────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# ─── Logging ──────────────────────────────────
LOG_LEVEL=info
